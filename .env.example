# ─── Remata Chatbot (landing page AI assistant) ───
# Set ONE API key. The provider is auto-detected or set explicitly.

# Universal key (works with CHATBOT_PROVIDER)
CHATBOT_API_KEY=

# Or use provider-specific keys:
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# Provider: "openai" | "deepseek" (optional — auto-detected from keys above)
CHATBOT_PROVIDER=deepseek

# Optional overrides
# CHATBOT_MODEL=deepseek-chat
# CHATBOT_BASE_URL=https://api.deepseek.com

# ─── Google Maps (property maps) ───
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
